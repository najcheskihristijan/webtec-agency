---
---
<section class="relative overflow-hidden pt-20 pb-32 lg:pb-40">
  <!-- Nightwatch-style Background Gradients -->
  <div class="absolute inset-0 bg-gray-950">
    <div class="absolute top-0 inset-x-0 h-[600px] bg-gradient-to-b from-blue-900/20 to-transparent opacity-60"></div>
    <div class="absolute bottom-0 inset-x-0 h-[400px] bg-gradient-to-t from-gray-950 via-gray-950 to-transparent"></div>
    <!-- Glowing Orb -->
    <div class="absolute top-20 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-blue-600/20 blur-[100px] rounded-full opacity-50 pointer-events-none"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-6 text-center z-10">
    
    <!-- Announcement Badge -->
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-blue-500/30 bg-blue-500/10 text-xs font-semibold text-blue-300 mb-8 backdrop-blur-sm">
      <span class="w-2 h-2 rounded-full bg-blue-400 animate-pulse"></span>
      New: Accurate Rank Tracking 2.0
    </div>

    <!-- Main Headline -->
    <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight text-white mb-8">
      SEO Data directly <br class="hidden md:block"/>
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-400">
        from the Source.
      </span>
    </h1>

    <!-- Subheadline -->
    <p class="text-lg md:text-xl text-gray-400 max-w-3xl mx-auto mb-12 leading-relaxed">
      The most accurate rank tracker on the market. Access unbiased SEO data from any location to simplify reporting and drive growth.
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-20">
      <a href="#" class="w-full sm:w-auto px-8 py-4 rounded-xl bg-blue-600 hover:bg-blue-500 text-white font-bold text-lg transition-all shadow-xl shadow-blue-500/20 hover:scale-105">
        Start Free Trial
      </a>
      <a href="#" class="w-full sm:w-auto px-8 py-4 rounded-xl bg-white/5 hover:bg-white/10 border border-white/10 text-white font-bold text-lg backdrop-blur-sm transition-all flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        Watch Demo
      </a>
    </div>

    <!-- Dashboard Mockup (CSS Only Placeholder for now) -->
    <div class="relative max-w-5xl mx-auto">
      <div class="rounded-xl border border-white/10 bg-gray-900/50 backdrop-blur-xl shadow-2xl p-2 shadow-blue-900/20">
        <div class="rounded-lg bg-gray-950 overflow-hidden aspect-[16/9] flex items-center justify-center relative group">
           <!-- Fake UI Elements representing a Dashboard -->
           <div class="absolute inset-x-8 top-8 h-8 flex gap-4">
              <div class="w-1/4 h-full bg-white/5 rounded-md animate-pulse"></div>
              <div class="w-1/4 h-full bg-white/5 rounded-md animate-pulse delay-75"></div>
              <div class="w-1/4 h-full bg-white/5 rounded-md animate-pulse delay-150"></div>
           </div>
           
           <div class="absolute inset-x-8 top-24 bottom-8 flex gap-8">
              <div class="w-2/3 h-full bg-white/5 rounded-lg border border-white/5 p-6">
                 <!-- Graph Lines -->
                 <div class="w-full h-full flex items-end justify-between gap-2">
                    <div class="w-full bg-blue-500/30 h-[40%] rounded-t-sm"></div>
                    <div class="w-full bg-blue-500/50 h-[60%] rounded-t-sm"></div>
                    <div class="w-full bg-blue-500/40 h-[35%] rounded-t-sm"></div>
                    <div class="w-full bg-blue-500/60 h-[75%] rounded-t-sm"></div>
                    <div class="w-full bg-blue-500/80 h-[90%] rounded-t-sm"></div>
                 </div>
              </div>
              <div class="w-1/3 h-full space-y-4">
                 <div class="h-1/3 w-full bg-white/5 rounded-lg"></div>
                 <div class="h-1/3 w-full bg-white/5 rounded-lg"></div>
                 <div class="h-1/3 w-full bg-white/5 rounded-lg"></div>
              </div>
           </div>

           <div class="text-gray-500 text-sm font-mono">Interactive Dashboard Preview</div>
        </div>
      </div>
      <!-- Reflection Effect -->
      <div class="absolute top-full inset-x-10 h-32 bg-gradient-to-b from-blue-500/20 to-transparent blur-3xl -z-10"></div>
    </div>
    
  </div>
</section>
