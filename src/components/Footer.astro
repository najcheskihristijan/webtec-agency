---
const today = new Date();
---

<footer class="bg-gray-950 border-t border-white/10 pt-20 pb-10">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-4 gap-12 mb-16">
      <div class="col-span-2 space-y-4">
        <a href="/" class="flex items-center gap-2 text-white font-bold text-2xl tracking-tight">
          <div class="w-8 h-8 rounded-lg bg-blue-600 flex items-center justify-center text-white">W</div>
          WEBTEC
        </a>
        <p class="text-gray-400 max-w-sm">
          Unbiased technical analysis, reviews, and infrastructure guides for the modern web.
        </p>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-4">Publication</h3>
        <ul class="space-y-3">
          <li><a href="/" class="text-gray-400 hover:text-white transition-colors">Home</a></li>
          <li><a href="/blog" class="text-gray-400 hover:text-white transition-colors">Latest News</a></li>
          <li><a href="/about" class="text-gray-400 hover:text-white transition-colors">About Us</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-4">Connect</h3>
        <ul class="space-y-3">
          <li><a href="#" class="text-gray-400 hover:text-white transition-colors">Twitter / X</a></li>
          <li><a href="#" class="text-gray-400 hover:text-white transition-colors">LinkedIn</a></li>
          <li><a href="#" class="text-gray-400 hover:text-white transition-colors">RSS Feed</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/5 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="text-gray-500 text-sm">
        &copy; {today.getFullYear()} Webtec. All rights reserved.
      </div>
      <div class="flex items-center gap-6 text-sm text-gray-500">
        <a href="#" class="hover:text-gray-300">Privacy Policy</a>
        <a href="#" class="hover:text-gray-300">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
