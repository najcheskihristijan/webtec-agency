---
const links = [
  { text: "Blog", href: "/blog" },
  { text: "About Us", href: "/about" },
  { text: "Contact Us", href: "/contact" },
];
---

<nav class="fixed top-6 left-0 right-0 z-50 px-4 pointer-events-none flex justify-center">
  <div class="pointer-events-auto w-full max-w-4xl bg-gray-900/60 backdrop-blur-xl border border-white/10 rounded-full shadow-2xl shadow-black/50 px-6 h-16 flex items-center justify-between transition-all duration-300 hover:bg-gray-900/80 hover:border-white/20">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group">
      <div class="w-8 h-8 rounded-lg bg-blue-600 flex items-center justify-center text-white font-bold text-lg shadow-lg shadow-blue-500/20 group-hover:shadow-blue-500/40 transition-all">
        W
      </div>
      <span class="text-xl font-bold text-white tracking-tight">Webtec</span>
    </a>

    <!-- Desktop Menu -->
    <div class="hidden md:flex items-center gap-8">
      {links.map(link => (
        <a href={link.href} class="text-sm font-medium text-gray-400 hover:text-white transition-colors">
          {link.text}
        </a>
      ))}
    </div>

    <!-- Mobile Menu Button (Placeholder) -->
    <button class="md:hidden text-gray-400 hover:text-white">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
    </button>
  </div>
</nav>

<script>
  // Add scroll effect if we want the navbar to be transparent at top and solid on scroll
  // (Currently kept consistent glassmorphism for premium feel)
</script>
