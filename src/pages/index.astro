---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featuredPost = posts[0];
const recentPosts = posts.slice(1);
---

<Layout title="Blog | Webtec Network">
	<main class="min-h-screen pb-20">
		<!-- Hero Section -->
		<section class="relative pt-32 pb-20 px-6 border-b border-white/5 bg-gradient-to-b from-gray-900/50 to-gray-950">
			<div class="max-w-7xl mx-auto text-center space-y-6">
				<h1 class="text-5xl md:text-7xl font-bold tracking-tighter text-white">
					Tech News. <span class="text-blue-500">Read Daily.</span>
				</h1>
				<p class="text-xl text-gray-400 max-w-2xl mx-auto font-light">
					Unbiased analysis of infrastructure, SEO, and the future of the web.
				</p>
			</div>
		</section>

		<!-- Featured Post -->
		{featuredPost && (
			<section class="max-w-7xl mx-auto px-6 py-12">
				<div class="relative group rounded-3xl overflow-hidden bg-gray-900 border border-white/10 hover:border-blue-500/30 transition-all duration-500">
					<div class="absolute inset-0 bg-gradient-to-t from-gray-950 via-transparent to-transparent z-10"></div>
					<div class="absolute inset-0 bg-blue-600/5 opacity-0 group-hover:opacity-100 transition-opacity z-10"></div>
					
					<div class="grid md:grid-cols-2 gap-8 items-center">
						<div class="h-64 md:h-[500px] w-full bg-gray-800 relative overflow-hidden">
							{featuredPost.data.heroImage ? (
								<img 
									src={featuredPost.data.heroImage} 
									alt={featuredPost.data.title} 
									class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
								/>
							) : (
								<div class="absolute inset-0 bg-gradient-to-br from-blue-900 to-gray-900 flex items-center justify-center text-white/5 text-9xl font-bold">
									W
								</div>
							)}
						</div>
						
						<div class="p-8 md:p-12 relative z-20 space-y-6">
							<div class="flex items-center gap-3 text-sm">
								<span class="px-3 py-1 rounded-full bg-blue-500/20 text-blue-300 font-medium">Featured</span>
								<time class="text-gray-400">
									{featuredPost.data.pubDate.toLocaleDateString('en-us', { month: 'long', day: 'numeric' })}
								</time>
							</div>
							
							<h2 class="text-4xl md:text-5xl font-bold text-white leading-tight group-hover:text-blue-400 transition-colors">
								<a href={`/blog/${featuredPost.id}`}>
									{featuredPost.data.title}
								</a>
							</h2>
							
							<p class="text-lg text-gray-400 line-clamp-3">
								{featuredPost.data.description}
							</p>

							<a href={`/blog/${featuredPost.id}`} class="inline-flex items-center text-blue-400 font-semibold hover:text-blue-300 transition-colors gap-2">
								Read Breakdown <span aria-hidden="true">&rarr;</span>
							</a>
						</div>
					</div>
				</div>
			</section>
		)}

		<!-- Recent Posts Grid -->
		<section class="max-w-7xl mx-auto px-6 py-12">
			<div class="flex items-center justify-between mb-8">
				<h1 class="text-2xl font-bold text-white">Latest Reports</h1>
				<a href="/blog" class="text-sm text-gray-400 hover:text-white transition-colors">View Archive</a>
			</div>
			
			<div class="grid md:grid-cols-3 gap-8">
				{recentPosts.map(post => (
					<a href={`/blog/${post.id}`} class="group space-y-4 block">
						<div class="aspect-video rounded-xl bg-gray-900 border border-white/10 group-hover:border-blue-500/30 overflow-hidden transition-all relative">
							{post.data.heroImage ? (
								<img 
									src={post.data.heroImage} 
									alt={post.data.title} 
									class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
								/>
							) : (
								<div class="absolute inset-0 bg-gradient-to-br from-gray-800 to-gray-900"></div>
							)}
						</div>
						<div class="space-y-2">
							<div class="text-xs text-blue-400 font-medium">News</div>
							<h4 class="text-xl font-bold text-white group-hover:text-blue-400 transition-colors leading-snug">
								{post.data.title}
							</h4>
							<p class="text-sm text-gray-400 line-clamp-2">
								{post.data.description}
							</p>
						</div>
					</a>
				))}
			</div>
		</section>
	</main>
</Layout>
