---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404: Page Not Found | Webtec">
  <main class="min-h-screen bg-gray-950 flex items-center justify-center px-6">
    <div class="max-w-xl w-full text-center space-y-8">
      
      <div class="relative">
        <h1 class="text-9xl font-bold text-gray-900 select-none">404</h1>
        <div class="absolute inset-0 flex items-center justify-center">
          <span class="text-3xl font-bold text-white bg-gray-950 px-4">Page Lost in Space</span>
        </div>
      </div>

      <p class="text-gray-400 text-lg">
        The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" class="px-8 py-3 bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-full transition-all shadow-lg shadow-blue-500/20">
          Go Home
        </a>
        <a href="/blog" class="px-8 py-3 bg-gray-900 border border-white/10 hover:border-white/20 text-white font-medium rounded-full transition-all">
          Read Latest News
        </a>
      </div>

    </div>
  </main>
</Layout>
