---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { slugify } from '../../utils/slugify';
import { authors, defaultAuthor } from '../../data/authors';

const { author } = Astro.params;
// Handle case where author param might be undefined or array
const authorSlug = author; 


console.log('[DEBUG] Visiting Author Page:', author);
if (!authorSlug) {
  console.log('[DEBUG] No author slug, redirecting');
  return Astro.redirect('/404');
}

const allPosts = await getCollection('blog');
console.log('[DEBUG] Posts found:', allPosts.length);

const posts = allPosts.filter((p) => {
  const rawAuthor = p.data.author || 'Webtec Editor';
  try {
    const postAuthorSlug = slugify(rawAuthor);
    return postAuthorSlug === authorSlug;
  } catch (e) {
    console.error('[ERROR] Slugify failed for:', rawAuthor, e);
    return false;
  }
});

console.log('[DEBUG] Filtered posts:', posts.length);

// Calculate actual author name from the posts or lookup
const authorKey = Object.keys(authors).find(key => key === authorSlug) || 'christian-webtec';
console.log('[DEBUG] Author Key:', authorKey);

const currentAuthor = authors[authorKey] || { ...defaultAuthor, name: 'Unknown Author' };


const authorName = currentAuthor.name;
const bio = currentAuthor.bio;
const avatar = currentAuthor.avatar;
const role = currentAuthor.role || "Author";
---

<Layout title={`${authorName} - Author Profile | Webtec`}>
  <main class="min-h-screen bg-gray-950 pb-20 pt-32">
    
    <!-- Author Header -->
    <section class="max-w-4xl mx-auto px-6 mb-20 text-center">
      <div class="w-32 h-32 mx-auto rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-4xl font-bold text-white shadow-2xl shadow-blue-500/20 mb-8 border-4 border-gray-900 overflow-hidden">
        {avatar ? (
          <img src={avatar} alt={authorName} class="w-full h-full object-cover" />
        ) : (
          authorName.charAt(0)
        )}
      </div>
      
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-2">
        {authorName}
      </h1>
      <div class="text-blue-400 font-mono text-sm uppercase tracking-widest mb-6">{role}</div>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed">
        {bio}
      </p>
      
      <div class="flex items-center justify-center gap-4 mt-8">
        <a href="#" class="text-gray-400 hover:text-white transition-colors">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg>
        </a>
        <a href="#" class="text-gray-400 hover:text-white transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
        </a>
      </div>
    </section>

    <!-- Author's Posts Grid -->
    <section class="max-w-7xl mx-auto px-6">
      <div class="flex items-center justify-between mb-8 border-b border-white/5 pb-4">
        <h2 class="text-2xl font-bold text-white">Published Articles</h2>
        <span class="text-gray-400 text-sm">{posts.length} Posts</span>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {posts.map(post => (
          <a href={`/blog/${post.id}`} class="group space-y-4 block">
            <div class="aspect-video rounded-xl bg-gray-900 border border-white/10 group-hover:border-blue-500/30 overflow-hidden transition-all relative">
              {post.data.heroImage ? (
                <img 
                  src={post.data.heroImage} 
                  alt={post.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              ) : (
                <div class="absolute inset-0 bg-gradient-to-br from-gray-800 to-gray-900"></div>
              )}
            </div>
            <div class="space-y-2">
              <time class="text-xs text-blue-400 font-medium">
                {post.data.pubDate.toLocaleDateString('en-us', { month: 'short', day: 'numeric', year: 'numeric' })}
              </time>
              <h3 class="text-xl font-bold text-white group-hover:text-blue-400 transition-colors leading-snug">
                {post.data.title}
              </h3>
              <p class="text-sm text-gray-400 line-clamp-2">
                {post.data.description}
              </p>
            </div>
          </a>
        ))}
      </div>
    </section>

  </main>
</Layout>
